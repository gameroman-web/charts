{
  "name": "charts",
  "private": true,
  "description": "Simple web tool for creating bar charts from CSV files",
  "type": "module",
  "imports": {
    "#styles": "./src/styles/global.css",
    "#app": "./src/components/App.tsx",
    "#lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "build": "astro build",
    "deploy": "wrangler deploy",
    "dev": "astro dev",
    "format": "biome check --write --linter-enabled=false",
    "lint": "biome check",
    "quality": "bun run --sequential format lint test typecheck",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "@babel/generator": "7.29.7",
    "@babel/helper-module-imports": "7.29.7",
    "@babel/parser": "7.29.7",
    "@babel/template": "7.29.7",
    "@babel/traverse": "7.29.7",
    "@babel/types": "7.29.7",
    "@jridgewell/trace-mapping": "0.3.31",
    "esbuild": "0.28.1",
    "is-docker": "4.0.0",
    "semver": "7.8.4",
    "unstorage": "2.0.0-alpha.7"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.1",
    "astro": "6.4.8",
    "solid-js": "1.9.13",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@astrojs/solid-js": "6.0.1",
    "@biomejs/biome": "2.5.1",
    "@gameroman/config": "0.2.2",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3",
    "wrangler": "4.105.0"
  }
}
