{
  "name": "charts",
  "private": true,
  "description": "Simple web tool for creating bar charts from CSV files",
  "type": "module",
  "imports": {
    "#styles": "./src/styles/global.css",
    "#app": "./src/components/App.tsx",
    "#lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "lint": "biome check",
    "format": "biome check --write --linter-enabled=false",
    "dev": "astro dev",
    "build": "astro build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "quality": "bun run format && bun run lint && bun run test && bun run typecheck",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.8",
    "solid-js": "^1.9.12",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/solid-js": "^6.0.1",
    "@biomejs/biome": "2.4.8",
    "@gameroman/config": "^0.0.5",
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2",
    "wrangler": "^4.77.0"
  }
}
